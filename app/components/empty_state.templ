package components

templ EmptyState() {
	<div class="col-span-full flex flex-col items-center justify-center py-24 border-2 border-dashed border-[var(--border)] bg-[var(--bg-subtle)]">
		<span class="text-5xl mb-4 font-black text-[var(--fg-muted)]">{"/"}</span>
		<h3 class="text-sm font-extrabold text-[var(--fg-muted)] uppercase tracking-tight">No drawings yet</h3>
		<p class="mt-2 text-xs text-[var(--fg-muted)]">Create your first drawing to get started.</p>
	</div>
}
